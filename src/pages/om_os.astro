<script>
  const instructorCarousel = document.getElementById("instructorsCarousel");
  const prevInstructor = document.getElementById("prevInstructor");
  const nextInstructor = document.getElementById("nextInstructor");

  if (instructorCarousel && prevInstructor && nextInstructor) {

    prevInstructor.addEventListener("click", () => {
      instructorCarousel.scrollBy({
        left: -400,
        behavior: "smooth"
      });
    });

    nextInstructor.addEventListener("click", () => {
      instructorCarousel.scrollBy({
        left: 400,
        behavior: "smooth"
      });
    });

  }
</script>
  <section class="about-section">

  <div class="container about-grid">

    <!-- VIDEO -->


    <!-- CONTENT -->
    <div class="about-content">

      <h2>Om os</h2>

      <p>
        Rumble Sports er et kampsportscenter ved Flintholm St., hvor fællesskab, disciplin og personlig udvikling er i fokus. Vi tilbyder træning i MMA, kickboxing og Brasiliansk Jiu-Jitsu for både begyndere, motionister og ambitiøse kæmpere.
      </p>

      <p>
        Hos os er alle velkomne – uanset erfaring og mål. Vores erfarne trænere skaber et motiverende og trygt træningsmiljø, hvor du kan udvikle dig fysisk og mentalt i dit eget tempo.
      </p>

      <p>
        Uanset om du ønsker bedre form, selvforsvar eller drømmer om konkurrencer, er målet at give dig den bedst mulige oplevelse og gøre dig til en del af et stærkt fællesskab.
      </p>

      <!-- CTA -->
      <div class="about-cta">

        <Cta
          href="/bliv_medlem"
          text="Bliv Medlem"
        />

      </div>

    </div>
    <div class="about-video-wrapper">

      <button class="about-video-btn" id="openAboutVideo">

        <img
          src="/om_os_video_thumbnail.jpg"
          alt="Rumble Sports Video"
          class="about-video-thumbnail"
        >

        <div class="play-button">
          ▶
        </div>

      </button>

    </div>
  </div>

  <!-- VIDEO MODAL -->
  <div class="about-modal" id="aboutModal">

    <button class="close-about-modal" id="closeAboutVideo">
      ✕
    </button>

    <video
      controls
      class="about-modal-video"
      id="aboutVideo"
    >
      <source src="/stor_video_til_om_os.mov" type="video/mp4">
    </video>

  </div>

</section>

<script>
  const openAboutVideo = document.getElementById("openAboutVideo");
  const closeAboutVideo = document.getElementById("closeAboutVideo");
  const aboutModal = document.getElementById("aboutModal");
 const aboutVideo = document.getElementById("aboutVideo") as HTMLVideoElement;

  if (
    openAboutVideo &&
    closeAboutVideo &&
    aboutModal &&
    aboutVideo
  ) {

    openAboutVideo.addEventListener("click", () => {

      aboutModal.classList.add("active");

      aboutVideo.play();

    });

    closeAboutVideo.addEventListener("click", () => {

      aboutModal.classList.remove("active");

      aboutVideo.pause();

      aboutVideo.currentTime = 0;

    });

    aboutModal.addEventListener("click", (event) => {

      if (event.target === aboutModal) {

        aboutModal.classList.remove("active");

        aboutVideo.pause();

        aboutVideo.currentTime = 0;

      }

    });

  }
</script>
