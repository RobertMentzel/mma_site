    display: none;
  }

  /* CARD */
  .instructor-card {
    position: relative;

    min-width: 100%;

    height: 500px;

    border-radius: var(--radius-lg);

    overflow: hidden;

    scroll-snap-align: center;

    flex-shrink: 0;
  }

  .instructor-card img {
    width: 100%;
    height: 100%;

    object-fit: cover;
  }

  /* LABEL */
  .instructor-label {
    position: absolute;

    left: 1rem;
    bottom: 1rem;

    background-color: var(--clr-accent);

    padding: 1rem 1.25rem;

    border-radius: var(--radius-md);

    backdrop-filter: blur(6px);
  }

  .instructor-label h3 {
    color: var(--clr-text);

    font-size: 1.1rem;
  }

  .instructor-label p {
    color: var(--clr-text);

    font-size: 0.95rem;
  }

  /* DESKTOP */
