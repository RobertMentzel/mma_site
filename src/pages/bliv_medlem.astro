  <!-- ACCORDION -->
  <div class="container accordion-wrapper">

    <h2>Medlemsbetingelser</h2>

    <div class="accordion">

  <details class="accordion-item">

    <summary>
      Medlemsbetingelse 1
    </summary>

    <p>
      Her skriver du den første medlemsbetingelse.
    </p>

  </details>

  <details class="accordion-item">

    <summary>
      Medlemsbetingelse 2
    </summary>

    <p>
      Her skriver du den anden medlemsbetingelse.
    </p>

  </details>

  <details class="accordion-item">

    <summary>
      Medlemsbetingelse 3
    </summary>

    <p>
      Her skriver du den tredje medlemsbetingelse.
    </p>

  </details>

</div>

  </div>

</section>
  </main>
</Layout>
<style>
  .page-hero {
    position: relative;

    width: 100%;
    min-height: 100vh;

    overflow: hidden;

    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* BACKGROUND IMAGE */
  .page-hero-bg {
    position: absolute;
    
    inset: 0;

    width: 100%;
    height: 100%;

    object-fit: cover;
object-position: 60% center;
    z-index: 1;
  }

  /* OVERLAY */
  .page-hero-overlay {
    position: absolute;
    inset: 0;

    background-color: rgba(0,0,0,0.5);

    z-index: 2;
  }

  /* CONTENT */
  .page-hero-content {
    position: relative;

    z-index: 3;

    display: flex;
    flex-direction: column;
    align-items: center;

    text-align: center;

    gap: 1.5rem;
  }

  .page-hero-content h1 {
    color: var(--clr-text);

    font-size: clamp(3rem, 12vw, 7rem);

    text-transform: uppercase;

    line-height: 0.9;
  }

  .page-hero-content p {
    color: var(--clr-text);

    max-width: 30ch;
  }

  .offers-section {
    padding-block: var(--space-xl);
  }

  /* MOBILE FIRST */
  .offers-grid {
    display: grid;

    gap: 4rem;
  }

  /* TEXT */
  .offers-content {
    display: flex;
    flex-direction: column;

    gap: 1.5rem;
  }

  .offers-content h2 {
    text-align: center;

    margin-bottom: 1rem;

    color: var(--clr-text);

    text-transform: uppercase;
  }

  .offers-content p {
    color: var(--clr-text-muted);

    line-height: 1.8;
  }

  /* MOBILE GALLERY = HORIZONTAL CAROUSEL */
  .offers-gallery {
    display: flex;

    gap: 1rem;

    overflow-x: auto;

    scroll-snap-type: x mandatory;

    scrollbar-width: none;
  }

  .offers-gallery::-webkit-scrollbar {
    display: none;
  }

  .offers-gallery img {
    min-width: 85%;

    height: 320px;

    object-fit: cover;

    border-radius: var(--radius-md);

    scroll-snap-align: center;

    box-shadow: var(--shadow-lg);

    flex-shrink: 0;
  }

  /* DESKTOP */
  @media (min-width: 1024px) {

    .offers-grid {
      grid-template-columns: repeat(12, 1fr);

      align-items: start;

      gap: 3rem;
    }

    /* TEXT SIDE */
    .offers-content {
      grid-column: 1 / 7;
    }

    .offers-content h2 {
      text-align: left;
    }

    /* GALLERY LAYOUT */
    .offers-gallery {
      grid-column: 7 / 13;

      display: grid;

      grid-template-columns: repeat(6, 1fr);
      grid-template-rows: repeat(3, 180px);

      gap: 1rem;

      overflow: visible;
    }

    .offers-gallery img {
      width: 100%;
      height: 100%;

      min-width: unset;

      border-radius: var(--radius-md);

      object-fit: cover;
    }

    /* IMAGE POSITIONING */

    /* TOP LEFT */
    .img-1 {
      grid-column: 1 / 4;
      grid-row: 1 / 2;
    }

    /* TALL RIGHT */
    .img-2 {
      grid-column: 4 / 7;
      grid-row: 1 / 3;
    }

    /* BELOW IMAGE 1 */
    .img-3 {
      grid-column: 1 / 4;
      grid-row: 2 / 3;
    }

    /* BOTTOM FLOOR */
    .img-4 {
      grid-column: 1 / 7;
      grid-row: 3 / 4;
    }
  }

  .schedule-section {
    padding-block: var(--space-xl);
  }

  /* MOBILE FIRST */
  .schedule-grid {
    display: grid;

    gap: 3rem;
  }

  /* IMAGE */
  .schedule-btn {
    background: none;
    border: none;

    cursor: pointer;

    width: 100%;
  }

  .schedule-image {
    width: 100%;

    border-radius: var(--radius-md);

    box-shadow: var(--shadow-lg);

    transition: transform 0.3s ease;
  }

  .schedule-btn:hover .schedule-image {
    transform: scale(1.02);
  }

  /* CONTENT */
  .schedule-content {
    display: flex;
    flex-direction: column;

    gap: 1.5rem;
  }

  .schedule-content h2 {
    color: var(--clr-text);

    text-transform: uppercase;

    text-align: center;
  }

  .schedule-content p {
    color: var(--clr-text-muted);

    line-height: 1.8;
  }

  /* SOCIALS */
  .schedule-socials {
    display: flex;

    gap: 1.5rem;
  }

  .schedule-socials a img {
    width: 40px;
    height: 40px;

    transition: transform 0.3s ease;
  }

  .schedule-socials a:hover img {
    transform: scale(1.1);
  }

  /* MODAL */
  .schedule-modal {
    position: fixed;
    inset: 0;

    background-color: rgba(0,0,0,0.85);

    display: flex;
    align-items: center;
    justify-content: center;

    padding: 2rem;

    opacity: 0;
    pointer-events: none;

    transition: 0.3s ease;

    z-index: 3000;
  }

  .schedule-modal.active {
    opacity: 1;

    pointer-events: auto;
  }

  .schedule-modal img {
    max-width: 100%;
    max-height: 90vh;

    border-radius: var(--radius-md);
  }

  .close-modal {
    position: absolute;

    top: 2rem;
    right: 2rem;

    background: none;
    border: none;

    color: white;

    font-size: 2rem;

    cursor: pointer;
  }

  /* DESKTOP */
  @media (min-width: 1024px) {

    .schedule-grid {
      grid-template-columns: repeat(2, 1fr);

      align-items: center;

      gap: 4rem;
    }

    .schedule-content h2 {
      text-align: left;
    }
  }

  .membership-section {
    padding-block: var(--space-xl);
  }

  /* TOP GRID */
  .membership-wrapper {
    display: grid;
align-items: stretch;
    gap: 3rem;
  }

  .membership-box {
    background-color: var(--clr-bg-light);

    padding: 3rem;

    border-radius: var(--radius-lg);

    display: flex;
    flex-direction: column;

    gap: 1.5rem;

    height: 100%;

    box-shadow: var(--shadow-lg);
  }
  

  .membership-box h2 {
    color: var(--clr-text);

    text-transform: uppercase;
  }

  .membership-box p {
    color: var(--clr-text-muted);

    line-height: 1.8;
  }

  /* FORM */
  .membership-form {
    display: flex;
    flex-direction: column;

    gap: 1rem;
  }

  .membership-form input {
    width: 100%;

    padding: 1rem;

    border: 2px solid transparent;

    border-radius: var(--radius-md);

    background-color: var(--clr-bg);

    color: var(--clr-text);

    font-size: 1rem;

    outline: none;

    transition: 0.3s ease;
  }

  .membership-form input:focus {
    border-color: var(--clr-accent);
  }
  .membership-form textarea {
  width: 100%;

  padding: 1rem;

  border: 2px solid transparent;

  border-radius: var(--radius-md);

  background-color: var(--clr-bg);

  color: var(--clr-text);

  font-size: 1rem;

  outline: none;

  resize: vertical;

  min-height: 140px;

  transition: 0.3s ease;
}

.membership-form textarea:focus {
  border-color: var(--clr-accent);
}

  /* ACCORDION */
  .accordion-wrapper {
    margin-top: 5rem;
  }

  .accordion-wrapper h2 {
    margin-bottom: 2rem;

    text-align: center;

    text-transform: uppercase;
  }

  .accordion {
    display: flex;
    flex-direction: column;

    gap: 1rem;
  }

  .accordion-item {
    background-color: var(--clr-bg-light);

    border-radius: var(--radius-md);

    overflow: hidden;
  }

  .accordion-item summary {
    list-style: none;

    cursor: pointer;

    padding: 1.25rem 1.5rem;

    font-weight: 700;

    color: var(--clr-text);

    position: relative;
  }

  .accordion-item summary::after {
    content: "+";

    position: absolute;

    right: 1.5rem;

    transition: 0.3s ease;
  }

  .accordion-item[open] summary::after {
    transform: rotate(45deg);
  }

  .accordion-item p {
    padding: 0 1.5rem 1.5rem;

    color: var(--clr-text-muted);

    line-height: 1.7;
  }

  /* DESKTOP */
  @media (min-width: 1024px) {

    .membership-wrapper {
      grid-template-columns: repeat(2, 1fr);

      align-items: start;
    }

    .membership-box {
      padding: 3rem;
    }
  }
  .trial-bottom {
  margin-top: auto;

  display: flex;
  flex-direction: column;

  gap: 1.5rem;
}
</style>